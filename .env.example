# Required: Kalshi API authentication
KALSHI_API_KEY=your-kalshi-api-key
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.pem.txt

# Optional: Anthropic API key (not needed — pipeline uses Claude CLI via Max subscription)
# ANTHROPIC_API_KEY=sk-ant-...

# Recommended: data.gov API key — covers FEC, Congress.gov, FDA, FBI, GovInfo, NREL, Regulations.gov, USDA FoodData
# Also used by the us-gov-open-data MCP server. Get from: https://api.data.gov/signup/
# DATA_GOV_API_KEY=

# Optional: Metaculus API token (cross-market search)
# METACULUS_TOKEN=

# Optional: Congress.gov API key (free, get from api.congress.gov — used for bills + senate roster)
# CONGRESS_API_KEY=

# Optional: FRED API key (free, get from api.stlouisfed.org/api_key — required for economic data)
# FRED_API_KEY=

# --- MCP Server: US Gov Open Data (additional keys for government data APIs) ---
# The MCP server works without keys for 20+ APIs. These keys unlock more APIs or higher rate limits.

# Optional: BEA API key — Bureau of Economic Analysis (GDP breakdowns, trade data)
# Get from: https://apps.bea.gov/API/signup/
# BEA_API_KEY=

# Optional: BLS API key — Bureau of Labor Statistics (higher rate limits)
# Get from: https://www.bls.gov/developers/home.htm
# BLS_API_KEY=

# Optional: Census API key
# Get from: https://api.census.gov/data/key_signup.html
# CENSUS_API_KEY=
