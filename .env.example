# Required: Kalshi API authentication
KALSHI_API_KEY=your-kalshi-api-key
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.pem.txt

# Optional: Anthropic API key (not needed — pipeline uses Claude CLI via Max subscription)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: FEC API key (falls back to DEMO_KEY with lower rate limits)
# FEC_API_KEY=

# Optional: Metaculus API token (cross-market search)
# METACULUS_TOKEN=
